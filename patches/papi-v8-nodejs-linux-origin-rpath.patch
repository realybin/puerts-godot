Subject: [PATCH] fix: linux v8/nodejs use $ORIGIN rpath for PuertsCore
---
Index: unity/native/papi-v8/CMakeLists.txt
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/unity/native/papi-v8/CMakeLists.txt b/unity/native/papi-v8/CMakeLists.txt
--- a/unity/native/papi-v8/CMakeLists.txt	(revision a9a5564ed295897cba1e8a57f5021905df72233f)
+++ b/unity/native/papi-v8/CMakeLists.txt	(date 1782136500000)
@@ -141,6 +141,16 @@
   )
 endif()
 
+if(UNIX AND NOT APPLE AND NOT ANDROID AND NOT OHOS AND NOT (CMAKE_SYSTEM_NAME MATCHES "Emscripten"))
+    # Keep runtime lookup local to the built extension directory instead of
+    # inheriting build-tree absolute paths from transitive dependencies.
+    set_target_properties(PapiV8 PROPERTIES
+        BUILD_WITH_INSTALL_RPATH ON
+        BUILD_RPATH "\$ORIGIN"
+        INSTALL_RPATH "\$ORIGIN"
+    )
+endif()
+
 if ( WITH_WEBSOCKET EQUAL 3 )
     set(OPENSSL_SOURCE_DIR ${CMAKE_CURRENT_BINARY_DIR}/openssl-src) # default path by CMake
     set(OPENSSL_INSTALL_DIR ${CMAKE_CURRENT_BINARY_DIR}/openssl)
Index: unity/native/papi-nodejs/CMakeLists.txt
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/unity/native/papi-nodejs/CMakeLists.txt b/unity/native/papi-nodejs/CMakeLists.txt
--- a/unity/native/papi-nodejs/CMakeLists.txt	(revision a9a5564ed295897cba1e8a57f5021905df72233f)
+++ b/unity/native/papi-nodejs/CMakeLists.txt	(date 1782136500000)
@@ -118,6 +118,16 @@
    endif ()
 endif ()
 
+if(UNIX AND NOT APPLE AND NOT ANDROID AND NOT OHOS AND NOT (CMAKE_SYSTEM_NAME MATCHES "Emscripten"))
+    # Keep runtime lookup local to the built extension directory instead of
+    # inheriting build-tree absolute paths from transitive dependencies.
+    set_target_properties(PapiNodejs PROPERTIES
+        BUILD_WITH_INSTALL_RPATH ON
+        BUILD_RPATH "\$ORIGIN"
+        INSTALL_RPATH "\$ORIGIN"
+    )
+endif()
+
 if ( WIN32 AND NOT CYGWIN )
     list(APPEND PUERTS_COMPILE_DEFINITIONS BUILDING_V8_SHARED)
 endif ()
